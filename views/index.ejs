<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="css/bootstrap.min.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/hero') %>

    <section id="about" class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <h2>About Our Auto Repair Center</h2>
                    <p class="lead">We deliver expert car service with trusted technicians, transparent pricing, and fast turnaround.</p>
                    <p>From oil changes and brake repair to full diagnostics, our team keeps your vehicle safe and running smoothly.</p>
                    <a href="/contact" class="btn btn-primary mt-3">Book a Service</a>
                </div>
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0">
                        <img src="images/carService.jpg" class="card-img-top" alt="Car service center">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="py-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2>Our Services</h2>
                <p class="text-muted">Professional maintenance and repair services for every vehicle.</p>
            </div>
            <div class="row g-4">
                <% if (services && services.length > 0) { %>
                    <% services.forEach(service => { %>
                        <div class="col-md-4">
                            <div class="card shadow-sm service-card h-100">
                                <% if (service.image) { %>
                                    <img src="<%= service.image %>" class="card-img-top" alt="<%= service.title %>">
                                <% } %>
                                <div class="card-body">
                                    <h5 class="card-title"><%= service.title %></h5>
                                    <p class="card-text"><%= service.description %></p>
                                    <p class="fw-bold">Price: ₹<%= service.price.toFixed(2) %></p>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-md-4">
                        <div class="card shadow-sm service-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Engine Diagnostics</h5>
                                <p class="card-text">Complete inspections to identify issues early and keep your engine running at peak performance.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm service-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Brake Repair</h5>
                                <p class="card-text">Fast brake checks and replacements to keep you safe on every drive.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm service-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Routine Maintenance</h5>
                                <p class="card-text">Oil changes, fluid checks, and tune-ups that extend the life of your vehicle.</p>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    

    <section id="contact" class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <h2>Contact Us</h2>
                    <p class="lead">Ready to schedule service? Send us a quick message and we will respond shortly.</p>
                    <p class="text-muted">Visit our shop, call us, or use the form to connect with our team.</p>
                </div>
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 p-4">
                        <form action="/contact" method="POST" class="row g-3">
                            <div class="col-12">
                                <label for="name" class="form-label">Full Name</label>
                                <input type="text" class="form-control" id="name" name="name" placeholder="Enter your full name" required>
                            </div>
                            <div class="col-12">
                                <label for="email" class="form-label">Email address</label>
                                <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required>
                            </div>
                            <div class="col-12">
                                <label for="message" class="form-label">Message</label>
                                <textarea class="form-control" id="message" name="message" rows="4" placeholder="Tell us how we can help" required></textarea>
                            </div>
                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-primary">Send Message</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script src="js/bootstrap.bundle.min.js"></script>
</body>
</html>