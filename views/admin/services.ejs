<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Services</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>Manage Services</h2>
                <p class="text-muted">All service offerings created by the admin.</p>
            </div>
            <a href="/admin/services/add" class="btn btn-primary">Add New Service</a>
        </div>

        <% if (services.length === 0) { %>
            <div class="alert alert-info">No services yet. Add a new service to get started.</div>
        <% } else { %>
            <div class="row g-4">
                <% services.forEach(service => {%>
                    <div class="col-md-6 h-10">
                        <div class="card shadow-sm h-20">
                            <div class="card-body h-20">
                                <h5 class="card-title"><%= service.title %></h5>
                                <p class="card-text"><%= service.description %></p>
                                <p class="fw-bold mb-1">Price: ₹<%= service.price.toFixed(2) %></p>
                                <% if (service.image) { %>
                                    <img src="<%= service.image %>" alt="<%= service.title %>" class="img-fluid mb-3 rounded image">
                                <% } %>
                                <p class="text-muted small">Created on <%= service.createdAt.toDateString() %></p>

                                <div class="mt-3 d-flex gap-2">
                                    <a href="/admin/services/<%= service._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form action="/admin/services/<%= service._id %>/delete" method="POST" style="display:inline-flex; margin:0;">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this service?')">Delete</button>
                                    </form>

                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
