<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services</title>
    <link rel="stylesheet" href="css/bootstrap.min.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/header') %>

    <section class="container py-5">
        <div class="text-center mb-5">
            <h2>Our Repair Services</h2>
            <p class="text-muted">Quality maintenance and repair solutions for every car.</p>
        </div>
        <% if (!services || services.length === 0) { %>
            <div class="alert alert-info">No services are currently available. Please check back later.</div>
        <% } else { %>
            <div class="row g-4">
                <% services.forEach(service => { %>
                    <div class="col-md-4">
                        <div class="card shadow-sm service-card h-100">
                            <% if (service.image) { %>
                                <img src="<%= service.image %>" alt="<%= service.title %>" class="card-img-top">
                            <% } %>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title"><%= service.title %></h5>
                                <p class="card-text flex-grow-1"><%= service.description %></p>
                                <p class="fw-bold mt-3">Price: ₹<%= service.price %></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </section>

    <%- include('partials/footer') %>

    <script src="js/bootstrap.bundle.min.js"></script>
</body>
</html>