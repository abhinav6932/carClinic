<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Services</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-5">
        <div class="row mb-4">
            <div class="col-md-8">
                <h2>Book Services</h2>
                <p class="text-muted">Choose a service from the list below and confirm your booking.</p>
            </div>
            <div class="col-md-4 text-end">
                <a href="/auth/dashboard" class="btn btn-secondary">Back to Dashboard</a>
            </div>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>

        <% if (!services || services.length === 0) { %>
            <div class="alert alert-info">No services are currently available. Please check back later.</div>
        <% } else { %>
            <div class="row g-4">
                <% services.forEach(service => { %>
                    <div class="col-md-4">
                        <div class="card shadow-sm service-card h-100">
                            <% if (service.image) { %>
                                <img src="<%= service.image %>" alt="<%= service.title %>" class="card-img-top">
                            <% } %>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title"><%= service.title %></h5>
                                <p class="card-text flex-grow-1"><%= service.description %></p>
                                <p class="fw-bold mt-3">Price: ₹<%= service.price %></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <% if (bookings.length > 0) { %>
            <div class="mt-5">
                <h4>Your Recent Bookings</h4>
                <div class="list-group">
                    <% bookings.forEach(booking => { %>
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><%= booking.serviceTitle %></h6>
                                    <p class="mb-1"><%= booking.service ? booking.service.description : '' %></p>
                                    <small>Price: ₹<%= booking.price.toFixed(2) %> • Status: <%= booking.status %></small>
                                </div>
                                <small class="text-muted"><%= new Date(booking.bookedAt).toLocaleDateString() %></small>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>